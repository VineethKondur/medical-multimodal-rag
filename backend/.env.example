# Medical Project - Environment Variables
# Save this as: backend/.env

# Groq API Key for LLM
# Get it from: https://console.groq.com/
# 1. Sign up at console.groq.com
# 2. Create a new API key
# 3. Replace the placeholder below with your actual key
GROQ_API_KEY=gsk_YOUR_ACTUAL_KEY_HERE_REPLACE_THIS

# Optional: Django settings (usually not needed for local development)
# DEBUG=True
# SECRET_KEY=your-secret-key-here
